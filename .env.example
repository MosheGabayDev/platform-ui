# -----------------------------------------------------------------------
# NextAuth
# -----------------------------------------------------------------------

# Secret used to sign/encrypt the next-auth session cookie.
# Generate with: openssl rand -base64 32
# Required in all environments. Add to SSM Parameter Store before production deploy.
NEXTAUTH_SECRET=replace-with-openssl-rand-base64-32

# Full public URL of the Next.js app.
# Development: http://localhost:3000
# Production: https://platform-ui.ai-data-platform.com (update when domain is set)
NEXTAUTH_URL=http://localhost:3000

# -----------------------------------------------------------------------
# Flask backend
# -----------------------------------------------------------------------

# Base URL of the Flask web-api service.
# Development (local TEST env): http://localhost:5000
# Production (in-cluster): http://web-api.platform.svc.cluster.local:5000
FLASK_API_URL=http://localhost:5000
